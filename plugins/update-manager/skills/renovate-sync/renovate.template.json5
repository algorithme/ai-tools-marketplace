// managed-by: update-manager#<sha>
// Generated by /renovate-sync — do not edit above the user-managed region.
// To regenerate after updating inventory.md or constraints.yml: /renovate-sync
//
// Renovate docs: https://docs.renovatebot.com/configuration-options/
{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',

  // gitAuthor — auto-filled by /renovate-sync from `git config user.{name,email}`.
  // Override this if you want Renovate commits attributed to a different identity.
  // Without it, Renovate defaults to renovate@whitesourcesoftware.com (Mend account),
  // which triggers "Unverified" on GitHub.com when Vigilant Mode is enabled.
  gitAuthor: '<<GIT_AUTHOR>>',

  // ── Base presets ────────────────────────────────────────────────────────────
  extends: [
    'config:recommended',
    // Include the next preset only when ≥80% of GHA uses: refs are SHA-pinned.
    // Remove if the repo uses tag-pinned actions (see inventory.md notes).
    'helpers:pinGitHubActionDigests',
  ],

  // ── Enabled managers ────────────────────────────────────────────────────────
  // Populated from ecosystem entries in inventory.md.
  // Remove managers for ecosystems not present in the project.
  enabledManagers: [
    'cargo',           // Rust — Cargo.toml / Cargo.lock
    'pip_requirements', // Python (pip) — requirements*.txt
    'poetry',          // Python (Poetry) — pyproject.toml + poetry.lock
    'pep621',          // Python (uv/hatch) — pyproject.toml
    'npm',             // Node — package.json + lockfile
    'dockerfile',      // Dockerfile base images
    'docker-compose',  // docker-compose.yml service images
    'github-actions',  // .github/workflows/*.yml uses: refs
  ],

  // ── Branch / commit conventions (mirrors /update-manager) ───────────────────
  branchPrefix: 'deps/',

  // ── Vulnerability alerts ────────────────────────────────────────────────────
  vulnerabilityAlerts: {
    enabled: true,
    labels: ['security'],
  },

  // ── Dependency dashboard ────────────────────────────────────────────────────
  dependencyDashboard: true,

  // ── Package rules ───────────────────────────────────────────────────────────
  packageRules: [

    // ── Automerge for safe tiers ─────────────────────────────────────────────
    {
      description: 'Automerge patch, digest, pin, and lockfile updates',
      matchUpdateTypes: ['patch', 'digest', 'pin', 'lockFileMaintenance'],
      automerge: true,
    },

    // ── Major bumps — deferred to /update-manager ────────────────────────────
    {
      description: 'Require dashboard approval for major bumps; handle with /update-manager',
      matchUpdateTypes: ['major'],
      dependencyDashboardApproval: true,
      prCreation: 'approval',
      labels: ['needs-update-manager'],
    },

    // ── Minor bumps — open PR but require review ─────────────────────────────
    {
      description: 'Open PRs for minor bumps without automerge',
      matchUpdateTypes: ['minor'],
      automerge: false,
    },

    // ── Per-ecosystem minor automerge (user opt-in via inventory.automerge_minor) ──
    // Each entry below is generated when a subproject in inventory.md has
    // automerge_minor: true. Placed after the default minor rule so it overrides.
    //
    // Example:
    //   {
    //     description: 'User opt-in (inventory.automerge_minor): automerge minor for github-actions',
    //     matchManagers: ['github-actions'],
    //     matchUpdateTypes: ['minor'],
    //     automerge: true,
    //   },

    // ── Constraints from update-manager.constraints.yml ─────────────────────
    // Each entry below is generated from a constraints.yml record.
    // Format: { matchPackageNames/matchPackagePatterns, allowedVersions, description }
    //
    // Example (generated — do not edit by hand; use update-manager.constraints.yml):
    //   {
    //     description: 'PostgreSQL 18 changes WAL format — DBA review required',
    //     matchPackageNames: ['postgres'],
    //     allowedVersions: '<17',
    //   },

    // ── manual-only from inventory.md ────────────────────────────────────────
    // Each entry below is generated from an inventory manual-only pattern.
    //
    // Example:
    //   {
    //     description: 'tokio: Major bumps require concurrency review',
    //     matchPackageNames: ['tokio'],
    //     dependencyDashboardApproval: true,
    //   },

    // ── excluded from inventory.md ───────────────────────────────────────────
    // Packages listed in inventory excluded[] are fully disabled.
    //
    // Example:
    //   {
    //     description: 'openssl-sys: ABI pinned to system libssl 1.1',
    //     matchPackageNames: ['openssl-sys'],
    //     enabled: false,
    //   },

    // region: user-managed
    // Add custom packageRules here. /renovate-sync will preserve this block.
    // endregion: user-managed

  ],
}
