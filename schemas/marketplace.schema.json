{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/omorel/ai-tools-marketplace/schemas/marketplace.schema.json",
  "title": "Marketplace",
  "description": "Schema for .claude-plugin/marketplace.json",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Marketplace identifier (kebab-case). Users install with /plugin install <plugin>@<name>.",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "version": {
          "type": "string",
          "description": "Marketplace catalog version (semver).",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+].+)?$"
        },
        "allowCrossMarketplaceDependenciesOn": {
          "type": "array",
          "description": "Other marketplace names whose plugins may be depended on.",
          "items": { "type": "string" }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/pluginEntry" }
    }
  },
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Plugin identifier (kebab-case).",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "source": {
          "oneOf": [
            {
              "type": "string",
              "description": "Explicit relative path within the marketplace repo (must start with ./).",
              "pattern": "^\\./[^.]"
            },
            { "$ref": "#/$defs/sourceGithub" },
            { "$ref": "#/$defs/sourceUrl" },
            { "$ref": "#/$defs/sourceGitSubdir" },
            { "$ref": "#/$defs/sourceNpm" }
          ]
        },
        "description": { "type": "string" },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+].+)?$"
        },
        "author": {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" }
          }
        },
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "license": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "strict": { "type": "boolean" }
      }
    },
    "sourceGithub": {
      "type": "object",
      "required": ["source", "repo"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "github" },
        "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "ref": { "type": "string" },
        "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "sourceUrl": {
      "type": "object",
      "required": ["source", "url"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "url" },
        "url": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "sourceGitSubdir": {
      "type": "object",
      "required": ["source", "url", "path"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "git-subdir" },
        "url": { "type": "string" },
        "path": { "type": "string" },
        "ref": { "type": "string" },
        "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    },
    "sourceNpm": {
      "type": "object",
      "required": ["source", "package"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "npm" },
        "package": { "type": "string" },
        "version": { "type": "string" },
        "registry": { "type": "string", "format": "uri" }
      }
    }
  }
}
