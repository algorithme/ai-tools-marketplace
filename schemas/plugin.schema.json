{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/omorel/ai-tools-marketplace/schemas/plugin.schema.json",
  "title": "Plugin manifest",
  "description": "Schema for .claude-plugin/plugin.json",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Plugin identifier (kebab-case, no spaces).",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "version": {
      "type": "string",
      "description": "Semver version string. Set here, not in marketplace.json.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([-+].+)?$"
    },
    "description": { "type": "string" },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string", "format": "uri" },
    "license": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "skills": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "commands": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "agents": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "hooks": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "mcpServers": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "lspServers": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "outputStyles": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "monitors": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "userConfig": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description"],
        "properties": {
          "description": { "type": "string" },
          "sensitive": { "type": "boolean" }
        }
      }
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["server"],
        "properties": {
          "server": { "type": "string" },
          "userConfig": { "type": "object" }
        }
      }
    }
  }
}
